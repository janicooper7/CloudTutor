# --- Database (Neon Postgres) ---
# Get this from https://console.neon.tech -> your project -> Connection Details.
# Use the POOLED connection string (host contains "-pooler") for the app runtime;
# serverless functions open many short-lived connections.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/cloudtutor?sslmode=require"

# --- Auth (NextAuth v5 / Auth.js — Google) ---
# A random secret used to sign session JWTs. Generate one with:
#   npx auth secret        (writes it for you)  — or —  openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth credentials. Create them at:
#   https://console.cloud.google.com/apis/credentials
#   -> Create OAuth client ID -> Web application
# Authorized redirect URI (add both if you deploy):
#   http://localhost:3000/api/auth/callback/google
#   https://YOUR_DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- AI (Anthropic Claude) ---
# Generates structured lesson feedback from a transcript (see src/lib/ai.ts).
# Create a key at https://console.anthropic.com -> API Keys.
ANTHROPIC_API_KEY=""

# --- Email (Resend) ---
# Sends the lesson-report PDF to the student on "Confirm & send".
# Create a key at https://resend.com -> API Keys.
RESEND_API_KEY=""
# From address. The default sandbox sender (onboarding@resend.dev) only delivers
# to your own Resend account email — fine for testing. For real students, verify
# a domain in Resend and set e.g. "CloudTutor <lessons@yourdomain.com>".
EMAIL_FROM=""

# --- Speech-to-text (Deepgram) ---
# Transcribes the two lesson audio tracks (student + tutor) into a labelled
# transcript. Create a key at https://console.deepgram.com -> API Keys.
DEEPGRAM_API_KEY=""

# --- Internal task secret ---
# Shared secret that lets /api/upload/complete trigger the background processing
# function (netlify/functions/process.mts) and nobody else — the function's URL is
# public. Generate any random string, e.g.  openssl rand -hex 32
INTERNAL_TASK_SECRET=""

# Copy this file to .env.local and fill in the real values:
#   cp .env.example .env.local

# ============================================================================
# Deploying to Netlify
# ============================================================================
# Lesson audio can't be POSTed in one shot on serverless (Netlify's 6 MB body
# limit + 26–60 s function timeout), so it's chunk-uploaded to Netlify Blobs and
# processed by a 15-minute background function (netlify/functions/process.mts).
# Netlify Blobs needs zero setup on a linked site, but is NOT available under a
# plain `next dev` — use `netlify dev` to exercise the pipeline locally.
#
# In Netlify -> Site configuration -> Environment variables, set ALL of the keys
# above (DATABASE_URL, AUTH_SECRET, AUTH_GOOGLE_ID/SECRET, ANTHROPIC_API_KEY,
# RESEND_API_KEY, EMAIL_FROM, DEEPGRAM_API_KEY, INTERNAL_TASK_SECRET), plus:
#
#   AUTH_TRUST_HOST=true   # also pinned in netlify.toml; required or Google
#                          # sign-in redirects break behind Netlify's proxy.
#
# Then in Google Cloud Console -> Credentials -> your OAuth client, add the
# deployed callback to Authorized redirect URIs:
#   https://YOUR-SITE.netlify.app/api/auth/callback/google
#
# The capture extension is already URL-configurable: open its popup and set the
# app URL to your Netlify site — no rebuild needed.
